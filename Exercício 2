#include <stdio.h>
#include <stdlib.h>

#define MAX 10

typedef struct {
    char cliente[50]; // Mudado de 'nome' para 'cliente'
    int tempo_espera; // Mudado de 'tempo' para 'tempo_espera'
} Pedido; // Mudado de 'Pessoa' para 'Pedido'

Pedido fila[MAX];
int front = 0, rear = 0;

void enqueue(Pedido p) {
    fila[rear++] = p;
}

Pedido dequeue() {
    return fila[front++];
}

int main() {
    Pedido p;
    int total_minutos = 0, qtd_pedidos = 0; // Renomeadas para refletir o novo contexto

    // Inserindo novos dados de tempo de espera (em minutos)
    p.tempo_espera = 15; enqueue(p);
    p.tempo_espera = 8;  enqueue(p);
    p.tempo_espera = 12; enqueue(p);
    p.tempo_espera = 4;  enqueue(p);
    p.tempo_espera = 11; enqueue(p);

    while (front < rear) {
        Pedido aux = dequeue();
        total_minutos += aux.tempo_espera;
        qtd_pedidos++;
    }

    // Mantém o cálculo exato da média original
    float media = (float) total_minutos / qtd_pedidos;

    printf("Tempo medio de espera: %.2f minutos\n", media);

    // Mesma lógica de decisão (limite de corte em 8)
    if (media > 8)
        printf("Chamar mais motoboys para entrega\n");
    else
        printf("Equipe atual e suficiente\n");

    return 0;
}
